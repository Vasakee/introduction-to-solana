# Copy this to .env and replace the value with your secret key
# Option A: JSON array (the full 64-number secret key array)
# Example (shortened):
# SECRET_KEY=[1,2,3,4,5,6,7,8, ... ,64]

# Option B: Base58 string (if your helper accepts base58)
# SECRET_KEY=3u8...yourBase58Secret...

# Option C: point to a local keypair file
# SECRET_KEY_FILE=./keypair.json

# Note: token-metadata.ts imports dotenv/config, so .env will be loaded automatically.
